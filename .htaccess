# ============================================================
# .htaccess - DyP Consultora E-commerce
# ============================================================

# ----------------------------------------------------------
# 1. Enable Rewrite Engine
# ----------------------------------------------------------
RewriteEngine On
DirectoryIndex index.php index.html

# ----------------------------------------------------------
# 2. Force HTTPS
# ----------------------------------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------
# 3. Redirect www to non-www
# ----------------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ----------------------------------------------------------
# 4. Friendly URLs
# ----------------------------------------------------------

# /producto/SLUG → producto.php?slug=SLUG
RewriteRule ^producto/([a-zA-Z0-9_-]+)/?$ producto.php?slug=$1 [L,QSA]

# /categoria/SLUG → categoria.php?slug=SLUG
RewriteRule ^categoria/([a-zA-Z0-9_-]+)/?$ categoria.php?slug=$1 [L,QSA]

# /buscar/TERM → buscar.php?q=TERM
RewriteRule ^buscar/(.+)/?$ buscar.php?q=$1 [L,QSA]

# Sitemap
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Static page rewrites
RewriteRule ^tienda/?$ tienda.php [L,QSA]
RewriteRule ^carrito/?$ carrito.php [L]
RewriteRule ^checkout/?$ checkout.php [L]
RewriteRule ^mi-cuenta/?$ mi-cuenta.php [L]
RewriteRule ^mis-pedidos/?$ mis-pedidos.php [L]
RewriteRule ^wishlist/?$ wishlist.php [L]
RewriteRule ^login/?$ login.php [L]
RewriteRule ^logout/?$ logout.php [L]
RewriteRule ^contacto/?$ contacto.php [L]
RewriteRule ^gracias/?$ gracias.php [L]

# Don't rewrite real files/dirs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# ----------------------------------------------------------
# 5. Block direct access to sensitive files
# ----------------------------------------------------------

# Deny access to configuration and helper files
<FilesMatch "^(config|auth_helper|email_helper|db_setup_tienda)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# checkout_process.php - only allow POST requests
<Files "checkout_process.php">
    <IfModule mod_rewrite.c>
        RewriteEngine On
        RewriteCond %{REQUEST_METHOD} !^POST$
        RewriteRule .* - [F,L]
    </IfModule>
</Files>

# mp_webhook.php - only allow POST requests
<Files "mp_webhook.php">
    <IfModule mod_rewrite.c>
        RewriteEngine On
        RewriteCond %{REQUEST_METHOD} !^POST$
        RewriteRule .* - [F,L]
    </IfModule>
</Files>

# ----------------------------------------------------------
# 6. Block PHP execution in uploads directory
# ----------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/productos/.*\.ph(p[345s]?|t|tml)$ - [F,L]
</IfModule>

# ----------------------------------------------------------
# 7. Security headers
# ----------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ----------------------------------------------------------
# 8. Prevent directory listing
# ----------------------------------------------------------
Options -Indexes

# ----------------------------------------------------------
# 9. Cache static assets (30 days)
# ----------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    ExpiresByType font/woff2 "access plus 30 days"
    ExpiresByType font/woff "access plus 30 days"
    ExpiresByType font/ttf "access plus 30 days"
</IfModule>

# ----------------------------------------------------------
# 10. Gzip compression
# ----------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE text/plain
</IfModule>
